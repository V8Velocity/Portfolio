generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id        String   @id @default(cuid())

  name      String
  email     String
  message   String

  createdAt DateTime @default(now())
}

model PageView {
  id        String   @id @default(cuid())

  page      String
  referrer  String?
  userAgent String?

  createdAt DateTime @default(now())
}
